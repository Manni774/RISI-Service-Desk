<Page x:Class="RISI_Service_Desk.AddEditServicePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:RISI_Service_Desk"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Редактирование записи">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="52*"/>
            <RowDefinition Height="52*"/>
            <RowDefinition Height="56*"/>
            <RowDefinition Height="57*"/>
            <RowDefinition Height="64*"/>
            <RowDefinition Height="64*"/>
            <RowDefinition Height="89*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="233*"/>
            <ColumnDefinition Width="567*"/>
        </Grid.ColumnDefinitions>
        <TextBlock Grid.Row="2" Text="Название услуги" Height="22" Margin="10,18,64,18" Width="159" />
        <TextBlock Grid.Row="3" Text="Описание услуги" Height="20" Margin="10,19,138,20" Width="85"></TextBlock>
        <TextBlock Grid.Row="4" Text="Прайс" Height="22" Margin="10,22,127,22" Width="96"></TextBlock>
        <ComboBox x:Name="CmbNameServise" 
            Grid.Row="2" Grid.Column="1" 
            Margin="33,5,34,5"
            DisplayMemberPath="ServiceName"
            SelectedValuePath="ServiceName"
            SelectedValue="{Binding ServiceName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
        </ComboBox>
        <TextBox Text="{Binding Description}" MaxLength="500" 
            Grid.Row="3" Grid.Column="1" Margin="33,3,34,5"/>
        <TextBox Text="{Binding BasePrice}" MaxLength="500" 
            Grid.Row="4" Grid.Column="1" Margin="33,3,34,5"/>
        
        <TextBlock Grid.Row="0" x:Name="TitleText" 
                   FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="FieldsPanel"/>
        </ScrollViewer>

        <StackPanel Grid.Row="7" Grid.Column="1" Orientation="Horizontal" 
                    HorizontalAlignment="Left" Margin="357,0,0,0" Width="200">
            <Button Content="Сохранить" Click="BtnSave_Click" Width="90" Height="50"/>
            <Button Content="Отмена" IsCancel="True" Width="90" Height="50"
                    Background="LightGray" Foreground="Black"/>
        </StackPanel>
    </Grid>
</Page>
