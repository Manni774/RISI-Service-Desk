<Page x:Class="RISI_Service_Desk.AddEditServicePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:RISI_Service_Desk"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Страница редактирования таблицы услуг">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="54*"/>
            <RowDefinition Height="37*"/>
            <RowDefinition Height="71*"/>
            <RowDefinition Height="66*"/>
            <RowDefinition Height="66*"/>
            <RowDefinition Height="63*"/>
            <RowDefinition Height="92*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="233*"/>
            <ColumnDefinition Width="567*"/>
        </Grid.ColumnDefinitions>
        <TextBlock Grid.Row="2" Text="Название услуги:" Margin="10,0,10,0" VerticalAlignment="Center" HorizontalAlignment="Center" Height="51"/>
        <TextBlock Grid.Row="3" Text="Описание услуги:" Margin="10,0,16,0" VerticalAlignment="Center" HorizontalAlignment="Center" Height="48"/>
        <TextBlock Grid.Row="4" Text="Прайс:" Margin="10,0,16,0" VerticalAlignment="Center" HorizontalAlignment="Center" Height="46"/>
        <ComboBox x:Name="CmbNameServise" 
            Grid.Row="2" Grid.Column="1" 
            Margin="33,5,34,5"
            DisplayMemberPath="ServiceName"
            SelectedValuePath="ServiceName"
            SelectedValue="{Binding ServiceName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
        </ComboBox>
        <TextBox x:Name="txtDescription" Text="{Binding Description}" MaxLength="500" 
            Grid.Row="3" Grid.Column="1" Margin="33,3,34,5"/>
        <TextBox x:Name="txtBasePrice" Text="{Binding BasePrice}" MaxLength="500" 
            Grid.Row="4" Grid.Column="1" Margin="33,3,34,5"/>

        <StackPanel Grid.Row="6" Grid.Column="1" Orientation="Horizontal" 
                    HorizontalAlignment="Left" Margin="320,0,0,0" Width="237">
            <Button Content="Сохранить" Click="BtnSave_Click" Width="114" Height="50"/>
            <Button Content="Отмена" IsCancel="True" Width="100" Height="50"
                    Background="LightGray" Foreground="Black" Click="Button_Click"/>
        </StackPanel>
    </Grid>
</Page>
