<Page x:Class="RISI_Service_Desk.AddEditClientsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:RISI_Service_Desk"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Страница редактирования таблицы клиентов">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="26*"/>
            <RowDefinition Height="65*"/>
            <RowDefinition Height="65*"/>
            <RowDefinition Height="65*"/>
            <RowDefinition Height="66*"/>
            <RowDefinition Height="72*"/>
            <RowDefinition Height="90*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="233*"/>
            <ColumnDefinition Width="567*"/>
        </Grid.ColumnDefinitions>
        <TextBlock Grid.Row="1" Text="Название компании клиента:" VerticalAlignment="Center" HorizontalAlignment="Left" Height="25" Width="173" Margin="24,0,0,0"/>
        <TextBlock Grid.Row="2" Text="Контактное лицо:" VerticalAlignment="Center" HorizontalAlignment="Left" Height="25" Width="110" Margin="30,0,0,0"/>
        <TextBlock Grid.Row="3" Text="Телефон:" VerticalAlignment="Center" HorizontalAlignment="Left" Height="19" Width="90" Margin="30,0,0,0"/>
        <TextBlock Grid.Row="4" Text="Эл. адрес:" VerticalAlignment="Top" HorizontalAlignment="Left" Height="22" Width="90" Margin="30,20,0,0"/>
        <TextBox x:Name="txtName" Text="{Binding Name}" MaxLength="500" 
            Grid.Row="1" Grid.Column="1" Margin="33,3,34,5"/>
        <TextBox x:Name="txtContact" Text="{Binding ContactPerson}" MaxLength="500" 
            Grid.Row="2" Grid.Column="1" Margin="33,3,34,5"/>
        <TextBox x:Name="txtPhone" Text="{Binding Phone}" MaxLength="500" 
            Grid.Row="3" Grid.Column="1" Margin="33,3,34,5"/>
        <TextBox x:Name="txtEmail" Text="{Binding Email}" MaxLength="500" 
            Grid.Row="4" Grid.Column="1" Margin="33,3,34,5"/>

        <TextBlock Grid.Row="0" x:Name="TitleText" 
           FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>

        <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,2,0,2" Grid.Row="1">
            <StackPanel x:Name="FieldsPanel"/>
        </ScrollViewer>

        <StackPanel Grid.Row="6" Grid.Column="1" Orientation="Horizontal" 
            HorizontalAlignment="Left" Margin="320,0,0,0" Width="237">
            <Button Content="Сохранить" Click="BtnSave_Click" Width="114" Height="50"/>
            <Button Content="Отмена" IsCancel="True" Width="100" Height="50"
            Background="LightGray" Foreground="Black" Click="Button_Click"/>
        </StackPanel>
    </Grid>
</Page>
