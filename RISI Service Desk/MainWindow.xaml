<Window x:Class="RISI_Service_Desk.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:RISI_Service_Desk"
        mc:Ignorable="d"
        Title="RISI Service Desk" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Frame NavigationUIVisibility="Hidden" Grid.Row="1" Name ="MainFrame"/>
        <!-- Панель навигации по таблицам -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" 
                    Margin="10" HorizontalAlignment="Center">
            <Button Content="Клиенты" Click="BtnClients_Click" Width="100"/>
            <Button Content="Услуги" Click="BtnServices_Click" Width="100"/>
            <Button Content="Сотрудники" Click="BtnEmployees_Click" Width="100"/>
            <Button Content="Заявки" Click="BtnRequests_Click" Width="100"/>
        </StackPanel>
    </Grid>
</Window>
