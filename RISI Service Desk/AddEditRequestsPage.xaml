<Page x:Class="RISI_Service_Desk.AddEditRequestsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:RISI_Service_Desk"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="AddEditRequestsPage">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="26*"/>
            <RowDefinition Height="57*"/>
            <RowDefinition Height="58*"/>
            <RowDefinition Height="59*"/>
            <RowDefinition Height="56*"/>
            <RowDefinition Height="58*"/>
            <RowDefinition Height="73*"/>
            <RowDefinition Height="62*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="166*"/>
            <ColumnDefinition Width="355*"/>
            <ColumnDefinition Width="279*"/>
        </Grid.ColumnDefinitions>
        <TextBlock Grid.Row="1" Text="Id Клиента:" VerticalAlignment="Center" HorizontalAlignment="Left" Height="25" Width="173" Margin="24,0,0,0" Grid.ColumnSpan="2"/>
        <TextBlock Grid.Row="2" Text="Id Услуги:" VerticalAlignment="Center" HorizontalAlignment="Center" Height="25" Width="110"/>
        <TextBlock Grid.Row="3" Text="Id Сотрудника:" VerticalAlignment="Center" HorizontalAlignment="Left" Height="19" Width="90" Margin="30,0,0,0"/>
        <TextBlock Grid.Row="1" Grid.Column="2" Text="Дата запроса:" VerticalAlignment="Center" HorizontalAlignment="Left" Height="22" Width="90" Margin="30,0,0,0"/>
        <TextBlock Grid.Row="5" Text="Описание:" VerticalAlignment="Center" HorizontalAlignment="Left" Height="22" Width="90" Margin="30,0,0,0"/>
        <TextBlock Grid.Row="6" Text="Статус:" VerticalAlignment="Center" HorizontalAlignment="Left" Height="22" Width="90" Margin="30,0,0,0"/>
        <TextBlock Grid.Row="4" Text="Приоритет:" VerticalAlignment="Center" HorizontalAlignment="Left" Height="22" Width="90" Margin="30,0,0,0"/>
        <TextBlock Grid.Row="3" Grid.Column="2" Text="Дедлайн:" VerticalAlignment="Center" HorizontalAlignment="Left" Height="22" Width="90" Margin="30,0,0,0"/>
        <ComboBox x:Name="CmbClient" 
            Grid.Row="1" Grid.Column="1" 
            Margin="33,5,34,5"
            DisplayMemberPath="Name"
            SelectedValuePath="Id"
            SelectedValue="{Binding ClientId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
        </ComboBox>
        <ComboBox x:Name="CmbService" 
            Grid.Row="2" Grid.Column="1" 
            Margin="33,5,34,5"
            DisplayMemberPath="ServiceName"
            SelectedValuePath="Id"
            SelectedValue="{Binding ServiceId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
        </ComboBox>
        <ComboBox x:Name="CmbEmployee" 
            Grid.Row="3" Grid.Column="1"
            Margin="33,5,34,5"
            DisplayMemberPath="FullName"
            SelectedValuePath="Id"
            SelectedValue="{Binding EmployeeId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
        </ComboBox>
        <TextBox x:Name="txtPriority" Text="{Binding Priority}" MaxLength="500" 
            Grid.Row="4" Grid.Column="1" Margin="33,3,3,5"/>
        <TextBox x:Name="txtDescription" Text="{Binding Description}" MaxLength="500" 
            Grid.Row="5" Grid.Column="1" Margin="33,3,3,5"/>
        <TextBox x:Name="txtStatus" Text="{Binding Status}" MaxLength="500" 
            Grid.Row="6" Grid.Column="1" Margin="33,3,3,5"/>
        <DatePicker x:Name="dtpRequestDate" SelectedDate="{Binding RequestDate}" 
            Grid.Row="2" Grid.Column="2" Margin="0,5,0,5" Width="auto" HorizontalAlignment="Center"/>
        <DatePicker x:Name="dtpDeadLine" SelectedDate="{Binding DeadLine}" 
            Grid.Row="4" Grid.Column="2" Margin="0,5,0,5" Width="auto" HorizontalAlignment="Center"/>

        <StackPanel Grid.Row="7" Grid.Column="2" Orientation="Horizontal" 
            HorizontalAlignment="Left" Margin="5,0,0,0" Width="237">
            <Button Content="Сохранить" Click="BtnSave_Click" Width="114" Height="40"/>
            <Button Content="Отмена" IsCancel="True" Width="100" Height="40"
                Background="LightGray" Foreground="Black" Click="Button_Click"/>
        </StackPanel>
    </Grid>
</Page>
